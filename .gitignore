# 不忽略 .gitignore 本身
!.gitignore


# 忽略特定文件夹
# live-2d/2D/*
AI记录室/*
live-2d/build/
live-2d/fake_neuro_audio/
live-2d/node/
live-2d/.claude/
live-2d/Voice_Model_Factory
song-library/
full-hub/7z
full-hub/asr-hub
full-hub/bert-hub
full-hub/logs
full-hub/model
full-hub/rag-hub
full-hub/tts-hub
live-2d/webui/__pycache__


# 忽略所有 node_modules（无论在哪）
**/node_modules/

# 忽略可执行文件
*.exe
*.zip
*.log

#忽略无意义文件
runtime.log

# 整合包相关（不提交到仓库）
env/
*.tar.gz
魔塔上传/
测试下载/

# Claude 内部文件
.claude/

# Runtime caches and private memory data
__pycache__/
**/__pycache__/
*.pyc
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

plugins-dlc/memos/memos_system/data/**
!plugins-dlc/memos/memos_system/data/
!plugins-dlc/memos/memos_system/data/.gitkeep
!plugins-dlc/memos/memos_system/data/images/
!plugins-dlc/memos/memos_system/data/images/.gitkeep
!plugins-dlc/memos/memos_system/data/images/thumbnails/
!plugins-dlc/memos/memos_system/data/images/thumbnails/.gitkeep
!plugins-dlc/memos/memos_system/data/qdrant/
!plugins-dlc/memos/memos_system/data/qdrant/.gitkeep

live-2d/plugins/**/outputs/
live-2d/plugins/**/.runtime/
live-2d/plugins/.stats_client_id
live-2d/plugins/community/agent-dream/dream_logs/
live-2d/plugins/community/agent-dream/dream_state.json
