<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>879</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>AI桌宠控制中心</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* 主窗口背景 - 浅色渐变 */
QMainWindow {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 rgba(250, 249, 245, 255), stop:0.5 rgba(245, 243, 235, 255), stop:1 rgba(240, 238, 230, 255));
border-radius: 25px;
}

/* 中央部件 - 浅色渐变 */
QWidget#centralwidget {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 rgba(248, 247, 242, 255), stop:0.3 rgba(242, 240, 232, 255), stop:0.7 rgba(245, 243, 235, 255), stop:1 rgba(250, 248, 240, 255));
border-radius: 25px;
}

/* 侧边栏样式 - 浅灰渐变 */
QFrame#sidebar {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(235, 233, 225, 200), stop:0.5 rgba(230, 228, 220, 200), stop:1 rgba(225, 223, 215, 200));
border: 1px solid rgba(200, 195, 185, 150);
	border-radius: 20px;

}



/* 主内容区域 - 浅色毛玻璃效果 */
QFrame#contentArea {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 rgba(240, 238, 230, 200), stop:0.5 rgba(235, 233, 225, 200), stop:1 rgba(230, 228, 220, 200));
border: 1px solid rgba(200, 195, 185, 180);
	border-radius: 20px;

}

/* 堆叠控件背景 */
QStackedWidget {
	background-color: transparent;
}

/* 页面背景 */
QWidget#page, QWidget#page_2, QWidget#page_3, QWidget#page_4, QWidget#page_6, QWidget#page_terminal, QWidget#page_voice_clone, QWidget#page_tutorial, QWidget#page_tools, QWidget#page_ui_settings, QWidget#page_cloud_config, QWidget#page_prompt_market {
	background-color: transparent;
}

/* 标签样式 */
QLabel {
	color: rgb(114, 95, 77);

background-color: transparent;
}

/* 输入框样式 - 浅色毛玻璃效果 */
QLineEdit {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(250, 249, 245, 255), stop:1 rgba(248, 247, 242, 255));
border: 1px solid rgba(180, 175, 165, 200);
	border-radius: 10px;
	padding: 6px 9px;
	color: rgb(114, 95, 77);

}

QLineEdit:focus {
	border: 2px solid rgb(140, 135, 125);
background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(215, 213, 205, 255), stop:1 rgba(225, 223, 215, 255));
}

/* 文本编辑框样式 - 浅色毛玻璃效果 */
QTextEdit {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(250, 249, 245, 255), stop:1 rgba(248, 247, 242, 255));
border: 1px solid rgba(180, 175, 165, 200);
	border-radius: 14px;
	padding: 15px;
	color: rgb(114, 95, 77);
}

QTextEdit:focus {
	border: 2px solid rgb(140, 135, 125);
background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(245, 244, 240, 255), stop:1 rgba(248, 247, 242, 255));
}

/* 复选框样式 */
QCheckBox {
	color: rgb(114, 95, 77);
	spacing: 12px;
	background-color: transparent;
}

QCheckBox::indicator {
	width: 15px;
	height: 15px;
	border-radius: 4px;
border: 2px solid rgb(140, 135, 125);
	background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 rgba(230, 228, 220, 255), stop:1 rgba(240, 238, 230, 255));
}

QCheckBox::indicator:checked {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 rgba(120, 115, 105, 255), stop:1 rgba(100, 95, 85, 255));
border: 2px solid rgb(80, 75, 65);
}

QCheckBox::indicator:hover {
	border: 2px solid rgb(100, 95, 85);
}

/* 按钮样式 - 浅色渐变 */
QPushButton {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(250, 249, 245, 255), stop:0.5 rgba(248, 247, 242, 255), stop:1 rgba(245, 244, 240, 255));
color: rgb(114, 95, 77);
	border: 1px solid rgba(160, 155, 145, 180);
	border-radius: 8px;
	padding: 10px 20px;
}

QPushButton:hover {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(180, 175, 165, 255), stop:1 rgba(170, 165, 155, 255));
color: rgb(40, 35, 25);
}

QPushButton:pressed {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(160, 155, 145, 255), stop:1 rgba(150, 145, 135, 255));
}

/* 控制按钮特殊样式 */
#pushButton_toggle_live2d[state="start"],#pushButton_start_terminal,#pushButton_start_asr,#pushButton_start_bert,#pushButton_start_rag,#pushButton_start_minecraft_terminal {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(144, 238, 144, 255), stop:1 rgba(152, 251, 152, 255));
color: rgb(34, 139, 34);
}

#pushButton_toggle_live2d[state="stop"],#pushButton_stop_terminal,#pushButton_stop_asr,#pushButton_stop_bert,#pushButton_stop_rag {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(255, 182, 193, 255), stop:1 rgba(255, 160, 122, 255));
color: rgb(139, 69, 19);
}

/* 文件上传按钮特殊样式 */
#pushButton_select_model,#pushButton_select_audio {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 rgba(230, 245, 255, 255), stop:0.3 rgba(225, 240, 250, 255), stop:0.7 rgba(220, 235, 245, 255), stop:1 rgba(215, 230, 240, 255));
border: 2px dashed rgba(100, 150, 200, 180);
	border-radius: 15px;
	color: rgb(70, 100, 130);
	text-align: center;
}

#pushButton_select_model:hover,#pushButton_select_audio:hover {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 rgba(200, 230, 255, 255), stop:0.5 rgba(190, 220, 250, 255), stop:1 rgba(180, 210, 245, 255));
border: 2px dashed rgba(80, 130, 180, 220);
	color: rgb(50, 80, 110);
}

#pushButton_select_model:pressed,#pushButton_select_audio:pressed {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 rgba(170, 200, 230, 255), stop:1 rgba(160, 190, 220, 255));
}

/* 动作按钮特殊样式 */
#start_singing_btn,#stop_singing_btn {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(173, 216, 230, 255), stop:1 rgba(135, 206, 250, 255));
color: rgb(25, 25, 112);
	padding: 12px 20px;
	margin: 5px;
}

#start_singing_btn,#stop_singing_btn:hover {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(135, 206, 250, 255), stop:1 rgba(100, 149, 237, 255));
color: rgb(0, 0, 139);
}

/* 保存按钮特殊样式 */
QPushButton#saveConfigButton {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(200, 195, 185, 255), stop:0.5 rgba(190, 185, 175, 255), stop:1 rgba(210, 205, 195, 255));
color: rgb(70, 65, 55);

}

QPushButton#saveConfigButton:hover {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(170, 165, 155, 255), stop:1 rgba(160, 155, 145, 255));
color: rgb(40, 35, 25);
}

/* 教程按钮特殊样式 */
QPushButton#pushButton_tutorial {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(255, 248, 220, 255), stop:1 rgba(255, 235, 205, 255));
color: rgb(139, 69, 19);
	border: 2px solid rgba(205, 133, 63, 150);
	border-radius: 12px;
}

QPushButton#pushButton_tutorial:hover {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(255, 228, 181, 255), stop:1 rgba(255, 218, 185, 255));
color: rgb(101, 67, 33);
	border: 2px solid rgba(184, 134, 11, 200);
}

/* QComboBox 下拉框样式 */
QComboBox {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(250, 249, 245, 255), stop:1 rgba(248, 247, 242, 255));
border: 1px solid rgba(180, 175, 165, 200);
	border-radius: 14px;
	padding: 6px 9px;
	color: rgb(114, 95, 77);

}

QComboBox:focus {
	border: 2px solid rgb(140, 135, 125);
background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(215, 213, 205, 255), stop:1 rgba(225, 223, 215, 255));
}

QComboBox::drop-down {
	subcontrol-origin: padding;
	subcontrol-position: top right;
	width: 30px;
	border-left: 1px solid rgba(180, 175, 165, 200);
border-top-right-radius: 14px;
	border-bottom-right-radius: 14px;
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(240, 238, 230, 255), stop:1 rgba(235, 233, 225, 255));
}

QComboBox::down-arrow {
	width: 12px;
	height: 12px;
	image: none;
	border: 2px solid rgb(114, 95, 77);
	border-top: none;
border-right: none;
	transform: rotate(-45deg);
	margin: 5px;
}

QComboBox QAbstractItemView {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(250, 249, 245, 255), stop:1 rgba(248, 247, 242, 255));
border: 1px solid rgba(180, 175, 165, 200);
	border-radius: 8px;
	selection-background-color: rgba(190, 185, 175, 255);
	color: rgb(114, 95, 77);
	padding: 5px;
}

/* 标签页样式 */
QTabWidget::pane {
	border: 1px solid rgba(180, 175, 165, 200);
border-radius: 12px;
	background: transparent;
	margin-top: 5px;
}

QTabBar::tab {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(250, 249, 245, 255), stop:1 rgba(245, 244, 240, 255));
color: rgb(114, 95, 77);
	border: 1px solid rgba(180, 175, 165, 200);
	border-bottom: none;
	border-top-left-radius: 10px;
	border-top-right-radius: 10px;
	padding: 10px 30px;
	margin-right: 5px;

}

QTabBar::tab:selected {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(240, 238, 230, 255), stop:1 rgba(235, 233, 225, 255));
color: rgb(70, 65, 55);
	border-bottom: 1px solid rgba(240, 238, 230, 255);
	border: 2px solid rgba(140, 135, 125, 200);
	border-bottom: none;
}

QTabBar::tab:hover {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(230, 228, 220, 255), stop:1 rgba(225, 223, 215, 255));
border: 2px solid rgba(160, 155, 145, 180);
	border-bottom: none;
}

/* 滚动条样式 */
QScrollBar:vertical {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(225, 223, 215, 255), stop:1 rgba(235, 233, 225, 255));
width: 10px;
	border-radius: 5px;
}

QScrollBar::handle:vertical {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(160, 155, 145, 255), stop:1 rgba(140, 135, 125, 255));
border-radius: 5px;
	min-height: 20px;
}

QScrollBar::handle:vertical:hover {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(120, 115, 105, 255), stop:1 rgba(100, 95, 85, 255));
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
	height: 0px;
}

/* 标题样式 */
QLabel#sectionTitle {
	color: rgb(114, 95, 77);

	background-color: transparent;
}



/* 菜单栏样式 */
QMenuBar {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(235, 233, 225, 255), stop:1 rgba(230, 228, 220, 255));
color: rgb(70, 65, 55);
	border-radius: 25px 25px 0px 0px;
}

QMenuBar::item:selected {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(200, 195, 185, 255), stop:1 rgba(180, 175, 165, 255));
color: rgb(40, 35, 25);
}

/* 状态栏样式 */
QStatusBar {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(235, 233, 225, 255), stop:1 rgba(230, 228, 220, 255));
color: rgb(70, 65, 55);
	border-radius: 0px 0px 25px 25px;
}

/* 控制面板样式 */
QFrame#control_panel_frame {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(240, 238, 230, 255), stop:1 rgba(235, 233, 225, 255));
border: 1px solid rgba(200, 195, 185, 180);
	border-radius: 15px;
}

/* 终端日志标签页特殊样式 */
QTabWidget#tabWidget_logs::pane {
	border: 1px solid rgba(180, 175, 165, 200);
	border-radius: 12px;
	background: transparent;
	margin-top: 5px;
}

QTabWidget#tabWidget_logs QTabBar::tab {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(250, 249, 245, 255), stop:1 rgba(245, 244, 240, 255));
color: rgb(114, 95, 77);
	border: 1px solid rgba(180, 175, 165, 200);
	border-bottom: none;
	border-top-left-radius: 10px;
	border-top-right-radius: 10px;
	padding: 8px 15px;
margin-right: 2px;

}

QTabWidget#tabWidget_logs QTabBar {
	qproperty-expanding: true;
}

QTabWidget#tabWidget_logs QTabBar::tab:selected {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(240, 238, 230, 255), stop:1 rgba(235, 233, 225, 255));
color: rgb(70, 65, 55);
	border-bottom: 1px solid rgba(240, 238, 230, 255);
	border: 2px solid rgba(140, 135, 125, 200);
	border-bottom: none;
}

QTabBar::tab:hover {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(230, 228, 220, 255), stop:1 rgba(225, 223, 215, 255));
border: 2px solid rgba(160, 155, 145, 180);
	border-bottom: none;
}

/* 工具屋页面样式 */
QWidget#page_tools {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(252, 251, 247, 255), stop:1 rgba(247, 245, 237, 255));
	border-radius: 15px;
}

/* 工具屋标题样式 */
QLabel#label_tools_title {
	color: rgb(85, 70, 55);
	font-size: 18px;
	font-weight: bold;
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(240, 200, 160, 120), stop:1 rgba(200, 180, 140, 120));
	border: 2px solid rgba(180, 160, 120, 150);
	border-radius: 12px;
	padding: 12px;
	margin: 10px 20px;
}

/* 工具屋滚动区域样式 */
QScrollArea#scrollArea_tools {
	background: transparent;
	border: none;
	border-radius: 10px;
}

/* 工具列表样式 */
QListWidget#listWidget_tools {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(255, 254, 250, 255), stop:1 rgba(250, 248, 240, 255));
	border: 2px solid rgba(200, 185, 160, 180);
	border-radius: 12px;
	padding: 8px;
	font-size: 18px;
	selection-background-color: rgba(220, 200, 170, 180);
}

QListWidget#listWidget_tools::item {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(248, 246, 240, 255), stop:1 rgba(245, 243, 235, 255));
	border: 1px solid rgba(210, 195, 170, 120);
	border-radius: 8px;
	padding: 12px 16px;
	margin: 4px 2px;
	color: rgb(70, 60, 45);
}

QListWidget#listWidget_tools::item:hover {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(240, 220, 180, 200), stop:1 rgba(235, 215, 175, 200));
	border: 2px solid rgba(200, 170, 130, 180);
	color: rgb(50, 40, 25);
	transform: translateY(-1px);
}

QListWidget#listWidget_tools::item:selected {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(230, 210, 170, 220), stop:1 rgba(225, 205, 165, 220));
	border: 2px solid rgba(180, 150, 110, 200);
	color: rgb(40, 30, 15);
}

/* 状态指示样式 */
QListWidget#listWidget_tools::item[text^="● "] {
	color: rgb(70, 60, 45);
}

QListWidget#listWidget_tools::item[text^="● "]:first-letter {
	color: rgba(70, 150, 70, 255);
}

QListWidget#listWidget_tools::item[text^="○ "] {
	color: rgb(70, 60, 45);
}

QListWidget#listWidget_tools::item[text^="○ "]:first-letter {
	color: rgba(120, 120, 120, 255);
}

/* MCP工具列表样式 */
QListWidget#listWidget_mcp_tools {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(255, 254, 250, 255), stop:1 rgba(250, 248, 240, 255));
	border: 2px solid rgba(200, 185, 160, 180);
	border-radius: 12px;
	padding: 8px;
	font-size: 18px;
	selection-background-color: rgba(220, 200, 170, 180);
}

QListWidget#listWidget_mcp_tools::item {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(248, 246, 240, 255), stop:1 rgba(245, 243, 235, 255));
	border: 1px solid rgba(210, 195, 170, 120);
	border-radius: 8px;
	padding: 12px 16px;
	margin: 4px 2px;
	color: rgb(70, 60, 45);
}

QListWidget#listWidget_mcp_tools::item:hover {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(240, 220, 180, 200), stop:1 rgba(235, 215, 175, 200));
	border: 2px solid rgba(200, 170, 130, 180);
	color: rgb(50, 40, 25);
	transform: translateY(-1px);
}

QListWidget#listWidget_mcp_tools::item:selected {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(230, 210, 170, 220), stop:1 rgba(225, 205, 165, 220));
	border: 2px solid rgba(180, 150, 110, 200);
	color: rgb(40, 30, 15);
}

QListWidget#listWidget_mcp_tools::item[text^="● "] {
	color: rgb(70, 60, 45);
}

QListWidget#listWidget_mcp_tools::item[text^="● "]:first-letter {
	color: rgba(70, 150, 70, 255);
}

QListWidget#listWidget_mcp_tools::item[text^="○ "] {
	color: rgb(70, 60, 45);
}

QListWidget#listWidget_mcp_tools::item[text^="○ "]:first-letter {
	color: rgba(120, 120, 120, 255);
}

/* 工具屋标签页样式 */
QTabWidget#tabWidget_tools {
	background: transparent;
}

QTabWidget#tabWidget_tools::pane {
	border: 1px solid rgba(180, 175, 165, 200);
	border-radius: 12px;
	background: transparent;
	margin-top: 5px;
}

QTabWidget#tabWidget_tools QTabBar::tab {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(250, 249, 245, 255), stop:1 rgba(245, 244, 240, 255));
	color: rgb(114, 95, 77);
	border: 1px solid rgba(180, 175, 165, 200);
	border-bottom: none;
	border-top-left-radius: 10px;
	border-top-right-radius: 10px;
	padding: 12px 35px;
	margin: 0px 1px;
	font-family: 微软雅黑;
	font-size: 16px;
	min-width: 120px;
}

QTabWidget#tabWidget_tools QTabBar::tab:selected {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(240, 238, 230, 255), stop:1 rgba(235, 233, 225, 255));
	color: rgb(70, 65, 55);
	border-bottom: 1px solid rgba(240, 238, 230, 255);
	border: 2px solid rgba(140, 135, 125, 200);
	border-bottom: none;
}

QTabWidget#tabWidget_tools QTabBar::tab:hover {
	background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(230, 228, 220, 255), stop:1 rgba(225, 223, 215, 255));
	border: 2px solid rgba(160, 155, 145, 180);
	border-bottom: none;
}

QTabWidget#tabWidget_tools QTabBar {
	qproperty-expanding: true;
}</string>
